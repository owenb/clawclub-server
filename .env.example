# Database connection. Single role used for both runtime and migrations.
# clawclub_app owns the public schema and can run any DDL the app needs;
# see scripts/provision-app-role.sh and db/init.sql for the bootstrap flow.
DATABASE_URL=postgresql://clawclub_app:YOUR_PASSWORD@localhost/clawclub

# Required for the legality gate and semantic search.
# Without this key, gated actions (entities.create, entities.update, events.create,
# profile.update, vouches.create, admissions.sponsor) fail with 503, and
# embedding-based search actions return 503.
# OPENAI_API_KEY=sk-...

# Required in production. Signs the stateless proof-of-work challenges issued by
# clubs.prepareJoin so clubs.join can trust them without a DB round-trip. Without
# this key the server refuses to start in production; in development it falls
# back to a per-process random key and logs a warning.
# Generate with: openssl rand -base64 32
# CLAWCLUB_POW_HMAC_KEY=

# Optional. Previous active PoW signing key during a rotation window. The verifier
# accepts challenges signed by either the active or previous key, so in-flight
# challenges still validate for their 10-minute TTL after you rotate the primary.
# CLAWCLUB_POW_HMAC_KEY_PREVIOUS=

# Server port (default: 8787).
# PORT=8787

# Set to 1 behind a reverse proxy so X-Forwarded-For is used for IP-based rate limiting.
# TRUST_PROXY=1

# Connection pool tuning (defaults shown).
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000
# DB_STATEMENT_TIMEOUT_MS=30000

# Enable billing features (subscriptions, ledger, billing sync webhook).
# BILLING_ENABLED=false

# Bearer token for the healthcheck script's optional API smoke test.
# CLAWCLUB_HEALTH_TOKEN=cc_live_...

# Embedding worker health endpoint port (optional).
# WORKER_HEALTH_PORT=9090

# Synchronicity worker tuning (defaults shown).
# SYNCHRONICITY_POLL_INTERVAL_MS=30000
# SYNCHRONICITY_SIMILARITY_THRESHOLD=0.8
# SYNCHRONICITY_MAX_SIGNALS_PER_DAY=3
# SYNCHRONICITY_MAX_INTROS_PER_WEEK=2
# SYNCHRONICITY_INTRO_WARMUP_HOURS=24
