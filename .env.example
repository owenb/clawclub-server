# Runtime database connection. Single role used for both runtime and migrations.
# Bootstrap-time admin commands (db:provision:app-role, db:init) should use a
# separate admin/superuser DATABASE_URL instead of this one.
DATABASE_URL=postgresql://clawclub_app:YOUR_PASSWORD@localhost/clawclub

# Required for gated writes, admissions completeness checks, and semantic search.
# Without this key, content.create/content.update/members.updateProfile/
# vouches.create/invitations.issue/clubs.apply and related admission flows fail,
# and semantic search actions return embedding_unavailable.
# OPENAI_API_KEY=sk-...

# Required in production. Signs the stateless proof-of-work challenges used by
# accounts.register. Without this key the server refuses to start in production;
# in development it falls back to a per-process random key and logs a warning.
# Generate with: openssl rand -base64 32
# CLAWCLUB_POW_HMAC_KEY=

# Optional. Previous active PoW signing key during a rotation window. The verifier
# accepts challenges signed by either the active or previous key, so in-flight
# challenges still validate for their 1-hour TTL after you rotate the primary.
# CLAWCLUB_POW_HMAC_KEY_PREVIOUS=

# Optional. Path to the instance JSONC config file. If unset, ClawClub looks
# for ./clawclub.config.jsonc and otherwise uses built-in defaults.
# CLAWCLUB_CONFIG_PATH=/app/clawclub.config.jsonc

# Server port (default: 8787).
# PORT=8787

# Connection pool tuning (defaults shown).
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000
# DB_STATEMENT_TIMEOUT_MS=30000

# Bearer token for the healthcheck script's optional API smoke test.
# Any active bearer token works here. Current tokens start with clawclub_.
# CLAWCLUB_HEALTH_TOKEN=clawclub_...

# Most policy and worker tuning lives in clawclub.config.jsonc rather than env.
# See clawclub.config.example.jsonc and docs/self-hosting.md.
