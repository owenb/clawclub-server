# Runtime app connection. This role should be non-superuser and not BYPASSRLS.
DATABASE_URL=postgresql://clawclub_app:YOUR_PASSWORD@localhost/clawclub

# Optional privileged connection for migrations, seeds, bootstrap, and role provisioning.
# Leave unset in normal runtime environments.
# DATABASE_MIGRATOR_URL=postgresql://clawclub_migrator:YOUR_PASSWORD@localhost/clawclub

# Optional: fail healthcheck when DATABASE_URL is a superuser or BYPASSRLS role.
# CLAWCLUB_REQUIRE_SAFE_DB_ROLE=1
